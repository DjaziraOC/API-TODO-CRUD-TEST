				{
					"name": "0.2 Création Utilisateur Test",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{testUsername}}\",\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"{{testPassword}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/signup",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "signup"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Gestion flexible de la création utilisateur",
									"const status = pm.response.code;",
									"const response = pm.response.json();",
									"",
									"if (status === 201 || status === 200) {",
									"    console.log(\"✅ Utilisateur créé avec succès\");",
									"    ",
									"    // Extraire le token si fourni à l'inscription",
									"    if (response.token) {",
									"        pm.collectionVariables.set(\"authToken\", response.token);",
									"        console.log(\"   Token obtenu depuis signup\");",
									"    }",
									"    if (response.userId || (response.user && response.user._id)) {",
									"        pm.collectionVariables.set(\"userId\", response.userId || response.user._id);",
									"    }",
									"} else if (status === 409) {",
									"    console.log(\"⚠️  Utilisateur existe déjà (conflit 409)\");",
									"    console.log(\"   Tentative de login avec cet utilisateur...\");",
									"    pm.test(\"User already exists - will try login\", function() {",
									"        pm.expect(true).to.be.true;",
									"});",
									"} else if (status === 400) {",
									"    console.log(\"❌  Erreur de validation utilisateur\");",
									"    console.log(\"   Détails: \" + (response.error || response.message));",
									"} else {",
									"    console.log(`❌  Code ${status} - Utilisation d'un compte existant pour les tests`);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "0.3 Login Auto & Get Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"{{testPassword}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// ================ EXTRACTION DU TOKEN ================",
									"pm.test(\"Login réussi\", function() {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"// Fonction pour extraire le token de n'importe quelle structure",
									"const extractToken = (data, path = \"\") => {",
									"    if (!data) return null;",
									"    ",
									"    // Si data est déjà un string token",
									"    if (typeof data === 'string' && data.includes('.')) {",
									"        const parts = data.split('.');",
									"        if (parts.length === 3) return data; // Format JWT typique",
									"    }",
									"    ",
									"    // Rechercher récursivement",
									"    for (const key in data) {",
									"        const value = data[key];",
									"        const newPath = path ? `${path}.${key}` : key;",
									"        ",
									"        if (key.toLowerCase().includes('token') && typeof value === 'string') {",
									"            return value;",
									"        }",
									"        ",
									"        if (typeof value === 'object' && value !== null) {",
									"            const found = extractToken(value, newPath);",
									"            if (found) return found;",
									"        }",
									"    }",
									"    return null;",
									"};",
									"",
									"const authToken = extractToken(response);",
									"",
									"if (authToken) {",
									"    pm.collectionVariables.set(\"authToken\", authToken);",
									"    pm.environment.set(\"authToken\", authToken);",
									"    ",
									"    console.log(\"✅ TOKEN JWT OBTENU AUTOMATIQUEMENT !\");",
									"    console.log(\"   Format: \" + (authToken.split('.').length === 3 ? \"JWT valide\" : \"autre format\"));",
									"    console.log(\"   Longueur: \" + authToken.length + \" caractères\");",
									"    ",
									"    pm.test(\"Token valide\", function() {",
									"        pm.expect(authToken).to.be.a('string');",
									"        pm.expect(authToken.length).to.be.greaterThan(10);",
									"    });",
									"} else {",
									"    console.error(\"🚫 Aucun token trouvé dans la réponse\");",
									"    ",
									"    // Dernière tentative: chercher dans le texte brut",
									"    const rawResponse = pm.response.text();",
									"    const tokenRegex = /[\"']?(token|accessToken|access_token|authToken)[\"']?\\s*:\\s*[\"']([^\"']+)[\"']/i;",
									"    const match = rawResponse.match(tokenRegex);",
									"    if (match && match[2]) {",
									"        pm.collectionVariables.set(\"authToken\", match[2]);",
									"        console.log(\"✅ Token extrait via regex: \" + match[2].substring(0, 30) + \"...\");",
									"    }",
									"}",
									"",
									"// Extraire l'ID utilisateur",
									"const extractUserId = (data) => {",
									"    if (data.userId) return data.userId;",
									"    if (data.user && data.user._id) return data.user._id;",
									"    if (data._id) return data._id;",
									"    if (data.data && data.data.userId) return data.data.userId;",
									"    if (data.id) return data.id;",
									"    return null;",
									"};",
									"",
									"const userId = extractUserId(response);",
									"if (userId) {",
									"    pm.collectionVariables.set(\"userId\", userId);",
									"    console.log(\"   User ID: \" + userId);",
									"}",
									"// ====================================================="
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "🧪 1. TESTS CRUD - CHAMPS SPÉCIFIQUES",
			"item": [
				{
					"name": "1.1 CREATE - Tâche complète (tous champs)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
