								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"{{uniqueTitle}}\",\n    \"description\": \"Description de test conforme au modèle (max 1000 chars)\",\n    \"priority\": \"high\",\n    \"completed\": false,\n    \"dueDate\": \"2024-12-31T23:59:59.000Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Tests spécifiques au modèle Mongoose",
									"pm.test(\"Status 201 - Création réussie\", function() {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"const response = pm.response.json();",
									"const task = response.task; // IMPORTANT: la tâche est dans response.task",
									"",
									"console.log(\"🔍 Tâche créée:\");",
									"console.log(\"Titre:\", task.title);",
									"console.log(\"User:\", task.user);",
									"",
									"pm.test(\"Structure conforme au modèle Task\", function() {",
									"    ",
									"    pm.expect(task.title).to.eql(pm.collectionVariables.get(\"uniqueTitle\"));",
									"    pm.expect(task).to.have.property(\"_id\");",
									"    pm.expect(task).to.have.property(\"user\");",
									"    ",
									"    // Champs avec valeurs par défaut",
									"    pm.expect(task.completed).to.eql(false);",
									"    pm.expect(task.priority).to.eql(\"high\");",
									"    ",
									"    // Champs optionnels",
									"    pm.expect(task.description).to.eql(\"Description de test conforme au modèle (max 1000 chars)\");",
									"    pm.expect(task.dueDate).to.not.be.null;",
									"    ",
									"    // Timestamps automatiques",
									"    pm.expect(task).to.have.property(\"createdAt\");",
									"    pm.expect(task).to.have.property(\"updatedAt\");",
									"    ",
									"    // Sauvegarder l'ID pour les tests suivants",
									"    pm.collectionVariables.set(\"taskId\", task._id);",
									"    console.log(\"✅ Tâche créée - ID: \" + task._id);",
									"});",
									"",
									"pm.test(\"User field is ObjectId format\", function() {",
									"    const objectIdRegex = /^[0-9a-fA-F]{24}$/;",
									"    pm.expect(task.user).to.match(objectIdRegex);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
