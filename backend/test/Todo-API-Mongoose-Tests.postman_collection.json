					"    }",
					"};",
					"",
					"initVar(\"baseUrl\", \"http://localhost:5000\");",
					"initVar(\"testEmail\", \"{{testEmail}}\");",
					"initVar(\"testPassword\", \"{{testPassword}}\");",
