									"pm.collectionVariables.set(\"runId\", runId);",
									"pm.collectionVariables.set(\"testEmail\", testEmail);",
									"pm.collectionVariables.set(\"testPassword\", testPassword);",
									"pm.collectionVariables.set(\"testUsername\", testUsername);",
