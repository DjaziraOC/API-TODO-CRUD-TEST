				{
					"name": "0.1 Health Check & Setup",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Serveur actif\", function() {",
									"    pm.response.to.have.status(200);",
									"    const data = pm.response.json();",
									"    pm.expect(data.status).to.eql(\"OK\");",
									"    pm.expect(data.database).to.eql(\"connected\");",
									"});",
									"",
									"// Générer des IDs uniques pour éviter les conflits",
									"const timestamp = Date.now();",
									"const runId = `run_${timestamp}`;",
									"const testEmail = `test.${timestamp}@example.com`;",
									"const testPassword = \"{{testPassword}}\";",
									"const testUsername = `user_${timestamp}`;",
