###############################################################################
# 📁 .env.example - TEMPLATE DES VARIABLES D'ENVIRONNEMENT
# -----------------------------------------------------------------------------
# BUT: Documenter TOUTES les variables nécessaires au projet
# USAGE: Copier ce fichier en .env et remplacer les valeurs d'exemple
# COMMANDE: cp .env.example .env
#
# ⚠️  IMPORTANT: Ce fichier est versionné dans Git
#     Le fichier .env (avec les vraies valeurs) NE DOIT JAMAIS être versionné
###############################################################################

###############################################################################
# 🏷️  SECTION 1: APPLICATION - CONFIGURATION GÉNÉRALE
###############################################################################

# 🌍 Environnement d'exécution
#    Valeurs possibles: development, production, test
#    Impacte le comportement de l'application (logs, sécurité, etc.)
NODE_ENV=development

# 🔌 Port d'écoute du serveur
#    Port exposé par l'application (5000, 3000, 8080, etc.)
#    Doit être libre sur la machine et correspondre au port Docker si utilisé
PORT=5000

# 🌐 Adresse d'écoute du serveur
#    0.0.0.0 = accepte les connexions de toutes les interfaces réseau
#    127.0.0.1 = seulement localhost (plus restrictif)
HOST=0.0.0.0

###############################################################################
# 🗄️  SECTION 2: DATABASE - CONFIGURATION MONGODB
###############################################################################

# ☁️  MongoDB Atlas (Cloud - Production)
#    Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?<options>
#    Récupérer depuis: https://cloud.mongodb.com > Connect > Driver
#    ⚠️  URL COMPLÈTE avec nom de base de données et options
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/todo_production?retryWrites=true&w=majority&appName=Cluster0

# 💻 MongoDB Local (Développement)
#    Utilisé quand NODE_ENV=development et Docker n'est pas utilisé
#    Format: mongodb://<host>:<port>/<database>
MONGODB_LOCAL_URI=mongodb://localhost:27017/todo_development

# 🔐 Options de connexion MongoDB (Optionnel)
#    Timeout de connexion en millisecondes
MONGODB_CONNECT_TIMEOUT_MS=30000

###############################################################################
# 🔐 SECTION 3: JWT - JSON WEB TOKENS (AUTHENTIFICATION)
###############################################################################

# 🎫 SECRET pour les Access Tokens
#    GÉNÉRER AVEC: openssl rand -hex 32
#    Longueur minimum: 256 bits (32 caractères hex)
#    DOIT être différent de JWT_REFRESH_SECRET
JWT_SECRET=votre_super_secret_jwt_minimum_32_caractères_ici_changez_moi

# ⏱️  Durée de validité des Access Tokens
#    Format: nombre + unité (s=secondes, m=minutes, h=heures, d=jours)
#    Exemples: 15m, 1h, 24h, 7d
JWT_EXPIRES_IN=24h

# 🔄 SECRET pour les Refresh Tokens
#    GÉNÉRER AVEC: openssl rand -hex 32 (DIFFÉRENT de JWT_SECRET)
#    Utilisé pour rafraîchir les access tokens sans reconnecter l'utilisateur
JWT_REFRESH_SECRET=un_autre_secret_différent_pour_refresh_tokens_changez_moi

# ⏱️  Durée de validité des Refresh Tokens
#    Plus longue que les access tokens (jours/semaines)
JWT_REFRESH_EXPIRES_IN=7d

# 🏷️  Nom de l'émetteur (issuer) - Optionnel
#    Identifie l'application qui émet le token
JWT_ISSUER=todo-backend-api

###############################################################################
# 🛡️  SECTION 4: SÉCURITÉ & CRYPTOGRAPHIE
###############################################################################

# 🧂 Tours de sel pour BCrypt (hachage des mots de passe)
#    Coût algorithmique: plus élevé = plus sécurisé mais plus lent
#    Valeurs recommandées: 10-12 (équilibre sécurité/performance)
BCRYPT_SALT_ROUNDS=10

# 🌐 CORS (Cross-Origin Resource Sharing)
#    URL(s) autorisées à accéder à l'API (séparées par des virgules si multiples)
#    En développement: http://localhost:3000 (frontend React/Vue)
#    En production: https://votre-domaine.com
CORS_ORIGIN=http://localhost:3000

# ✅ CORS supplémentaires (Optionnel)
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

###############################################################################
# 🚦 SECTION 5: RATE LIMITING - LIMITATION DE REQUÊTES
###############################################################################

# ⏰ Fenêtre temporelle de limitation
#    Durée en millisecondes (15 minutes = 900000 ms)
RATE_LIMIT_WINDOW_MS=900000

# 📊 Nombre maximum de requêtes par fenêtre
#    100 requêtes toutes les 15 minutes par adresse IP
RATE_LIMIT_MAX_REQUESTS=100

# ⚙️  Configuration avancée Rate Limiting (Optionnel)
RATE_LIMIT_MESSAGE=Too many requests, please try again later.
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

###############################################################################
# 📝 SECTION 6: LOGGING - JOURNALISATION
###############################################################################

# 📊 Niveau de log
#    Niveaux: error, warn, info, verbose, debug, silly
#    En développement: debug (beaucoup d'infos)
#    En production: info ou warn (uniquement important)
LOG_LEVEL=info

# 📋 Format des logs
#    combined: Standard Apache combined log
#    common: Apache common log
#    dev: Logs colorés pour développement
#    short, tiny: Formats minimalistes
LOG_FORMAT=dev

# 📁 Dossier de stockage des logs (Optionnel)
LOG_DIR=./logs

# 📄 Rotation des logs (Optionnel)
LOG_MAX_SIZE=10m      # 10 mégaoctets par fichier
LOG_MAX_FILES=5       # Garder 5 fichiers maximum

###############################################################################
# 📧 SECTION 7: EMAIL - ENVOI D'EMAILS (OPTIONNEL)
###############################################################################

# 📮 Serveur SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# 🔐 Identifiants SMTP
# SMTP_USER=votre_email@gmail.com
# SMTP_PASS=votre_mot_de_passe_application  # ⚠️ Mot de passe APP, pas Gmail

# ✉️  Expéditeur par défaut
# EMAIL_FROM=noreply@votredomaine.com
# EMAIL_FROM_NAME="Todo App"

# 📨 Templates (Optionnel)
# EMAIL_RESET_PASSWORD_TEMPLATE=reset-password
# EMAIL_WELCOME_TEMPLATE=welcome
# EMAIL_VERIFICATION_TEMPLATE=verify-email

###############################################################################
# 📁 SECTION 8: UPLOAD - TÉLÉCHARGEMENT DE FICHIERS (OPTIONNEL)
###############################################################################

# 📏 Taille maximale des fichiers
# MAX_FILE_SIZE=10485760  # 10MB en bytes

# 📂 Dossier de stockage
# UPLOAD_PATH=./uploads

# 📎 Extensions autorisées
# ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

# ☁️  Cloud Storage (Optionnel - AWS S3, etc.)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_BUCKET_NAME=your-bucket-name
# AWS_REGION=us-east-1

###############################################################################
# 🔧 SECTION 9: DÉVELOPPEMENT - VARIABLES SPÉCIFIQUES AU DEV
###############################################################################

# 🔍 Debug Mode
#    Active les logs détaillés, désactive certaines vérifications sécurité
DEBUG=true

# ⚡ Hot Reload (si applicable)
# NODEMON_ENABLED=true

# 🧪 Données de test (Optionnel)
# SEED_DATABASE=true
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=Test123!

###############################################################################
# 🚀 SECTION 10: PRODUCTION - VARIABLES SPÉCIFIQUES À LA PROD
###############################################################################

# 🔒 Headers de sécurité
# HELMET_ENABLED=true
# CONTENT_SECURITY_POLICY=default-src 'self'

# 📊 Monitoring (Optionnel)
# SENTRY_DSN=https://votre_dsn@sentry.io/project_id
# NEW_RELIC_LICENSE_KEY=votre_licence_key

# ⚖️  Load Balancer/Proxy (si derrière Nginx/Apache)
# TRUST_PROXY=1
# PROXY_TIMEOUT=30000

###############################################################################
# 📋 SECTION 11: VALIDATION - NE PAS MODIFIER
###############################################################################

# ✅ Cette section vérifie que toutes les variables sont définies
#    Ne pas modifier ces valeurs

# Liste des variables REQUISES (doivent être définies dans .env)
# REQUIRED_VARS=NODE_ENV,PORT,MONGODB_URI,JWT_SECRET,JWT_EXPIRES_IN,BCRYPT_SALT_ROUNDS,CORS_ORIGIN

###############################################################################
# 🚨 INSTRUCTIONS D'UTILISATION
###############################################################################

# ÉTAPE 1: Copier ce template
#   $ cp .env.example .env
#
# ÉTAPE 2: Éditer .env avec vos vraies valeurs
#   $ nano .env  # ou ouvrir avec votre éditeur favori
#
# ÉTAPE 3: Remplacer TOUTES les valeurs contenant "votre_" ou "changez_moi"
#
# ÉTAPE 4: NE JAMAIS COMMITER .env DANS GIT
#   Vérifiez que .env est bien dans .gitignore
#
# ÉTAPE 5: Pour chaque environnement, créez un fichier spécifique:
#   .env.development  - Développement local
#   .env.test         - Environnement de test
#   .env.production   - Production
#   .env.staging      - Pré-production

###############################################################################
# 🔐 GÉNÉRATION DES SECRETS
###############################################################################

# Pour générer un secret JWT sécurisé:
#   Linux/Mac/WSL: openssl rand -hex 32
#   Windows PowerShell: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#
# Exemple de commande pour générer les deux secrets:
#   $ echo "JWT_SECRET=$(openssl rand -hex 32)" >> .env
#   $ echo "JWT_REFRESH_SECRET=$(openssl rand -hex 32)" >> .env

###############################################################################
# ✅ VÉRIFICATION
###############################################################################

# Pour vérifier que votre .env est correct:
#   1. Aucune variable ne contient "votre_" ou "changez_moi"
#   2. Les secrets JWT font au moins 32 caractères
#   3. MONGODB_URI contient votre vrai cluster
#   4. NODE_ENV est bien défini (development/production)

# Bon développement ! 🚀
###############################################################################